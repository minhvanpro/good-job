# ============================================================
# Database
# ============================================================
# Local: Docker PostgreSQL
DATABASE_URL=postgresql://goodjob:goodjob_secret@localhost:5432/goodjob
# Railway: Auto-provisioned PostgreSQL (set via Railway dashboard)
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

# ============================================================
# Redis
# ============================================================
# Local: Docker Redis
REDIS_URL=redis://localhost:6379
# Railway: Auto-provisioned Redis (set via Railway dashboard)
# REDIS_URL=redis://<user>:<password>@<host>:<port>

# ============================================================
# JWT
# ============================================================
JWT_SECRET=change-me-in-production

# ============================================================
# Server
# ============================================================
PORT=4000
# Local dev: frontend on Vite port
CORS_ORIGIN=http://localhost:5173
# Production: leave empty or set to your Railway domain
# CORS_ORIGIN=https://good-job.up.railway.app

# ============================================================
# Cloudinary (https://cloudinary.com/console)
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
